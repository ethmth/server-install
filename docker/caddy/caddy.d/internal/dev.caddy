# TODO: May be able to do this as a catch-all *.dev.pc.internal, with certificates covering all subdomains


https://3000.dev.pc.internal {
    tls /certs/3000.dev.pc.internal.crt /certs/3000.dev.pc.internal.key {
		on_demand
	}

    reverse_proxy http://host.docker.internal:3000
}

https://4173.dev.pc.internal {
    tls /certs/4173.dev.pc.internal.crt /certs/4173.dev.pc.internal.key {
		on_demand
	}

    reverse_proxy http://host.docker.internal:4173
}

https://5173.dev.pc.internal {
    tls /certs/5173.dev.pc.internal.crt /certs/5173.dev.pc.internal.key {
		on_demand
	}

    reverse_proxy http://host.docker.internal:5173
}